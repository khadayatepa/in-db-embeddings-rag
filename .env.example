# ---- OpenAI (used ONLY as a fallback if no in-DB ONNX model is loaded) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

# ---- Oracle DB (via SQLcl MCP server) ----
ORACLE_MCP_CONNECTION=DEBATE
SQLCL_COMMAND=sql

# Name of the in-database ONNX embedding model (load it to go zero-external)
INDB_MODEL=DOC_MODEL

# The question to ask
QUESTION=How can I let an AI assistant query my Oracle database safely?
